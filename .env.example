VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Google Drive OAuth
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an Authorized redirect URI in Google Cloud Console exactly
VITE_GOOGLE_REDIRECT_URI=

# AI Configuration
# Providers: mock (default, no key needed), openai, gemini, ollama
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Slack OAuth (create app at https://api.slack.com/apps)
VITE_SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Atlassian (Jira + Confluence) OAuth (create app at https://developer.atlassian.com/console/myapps/)
VITE_ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=

# For Cloudflare Workers local dev, copy secrets into .dev.vars as well
